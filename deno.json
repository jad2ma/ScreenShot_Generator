{
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "npm run dev",
    "dev:api": "deno run -A --watch=src/server.ts,src/routes/ src/server.ts",
    "check": "deno check src/server.ts",
    "generate": "deno run --allow-read --allow-write src/generate.ts",
    "generate:en": "deno run --allow-read --allow-write src/generate.ts --lang en",
    "convert": "deno run -A src/convert.ts",
    "convert:en": "deno run -A src/convert.ts --lang en",
    "build": "deno run -A src/build.ts",
    "build:en": "deno task generate:en && deno task convert:en"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "lib": ["deno.ns", "dom", "dom.iterable", "es2022"],
    "types": ["npm:@types/react@^18.3.1"]
  },
  "lint": {
    "exclude": ["src/ui/", "dist/", "node_modules/"]
  },
  "fmt": {
    "exclude": ["src/ui/", "dist/", "node_modules/", "**/*.md"]
  },
  "exclude": ["src/ui/", "dist/", "node_modules/"],
  "imports": {
    "@std/path": "jsr:@std/path@^1.0.0",
    "@std/fs": "jsr:@std/fs@^1.0.0",
    "puppeteer": "npm:puppeteer@23.11.0",
    "sharp": "npm:sharp@0.33.5",
    "hono": "npm:hono@4",
    "react": "npm:react@^18.3.1",
    "react-dom": "npm:react-dom@^18.3.1",
    "react-dom/server": "npm:react-dom@^18.3.1/server",
    "react-dom/client": "npm:react-dom@^18.3.1/client",
    "@types/react": "npm:@types/react@^18.3.1",
    "@types": "./src/types/index.ts",
    "@types/": "./src/types/",
    "@routes": "./src/routes/index.ts",
    "@routes/": "./src/routes/",
    "@ui": "./src/ui/index.ts",
    "@ui/": "./src/ui/",
    "@lib": "./src/lib/index.ts",
    "@lib/": "./src/lib/",
    "@renderer": "./src/renderer-components/index.ts",
    "@renderer/": "./src/renderer-components/"
  }
}
